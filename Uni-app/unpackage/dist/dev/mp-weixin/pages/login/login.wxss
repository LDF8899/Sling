  overflow: hidden;
}

/* Background decoration */
.background-overlay.data-v-e4e4508d {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 20% 80%, rgba(102, 126, 234, 0.15) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(118, 75, 162, 0.15) 0%, transparent 50%);
  animation: pulse-e4e4508d 15s ease-in-out infinite alternate;
}
@keyframes pulse-e4e4508d {
0% {
    opacity: 0.8;
}
100% {
    opacity: 1;
}
}
/* Main container */
.login-main.data-v-e4e4508d {
  display: grid;
  grid-template-columns: 1fr 1fr;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
  gap: 40px;
  z-index: 1;
  position: relative;
}
@media (max-width: 768px) {
.login-main.data-v-e4e4508d {
    grid-template-columns: 1fr;
