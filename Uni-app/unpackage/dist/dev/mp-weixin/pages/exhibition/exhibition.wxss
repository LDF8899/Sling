.exhibition-container.data-v-faae53d7 {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* Top navbar */
.navbar.data-v-faae53d7 {
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.95);
  -webkit-backdrop-filter: blur(20px);
          backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(226, 232, 240, 0.5);
  padding: 15px;
}
.navbar-content.data-v-faae53d7 {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.navbar-left.data-v-faae53d7 {
  position: absolute;
  left: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}
.navbar-left.data-v-faae53d7:active {
  background: rgba(0, 0, 0, 0.1);
  transform: scale(0.9);
}
.back-icon.data-v-faae53d7 {
  font-size: 24px;
  color: #1e293b;
  font-weight: bold;
  line-height: 1;
}
.navbar-title.data-v-faae53d7 {
  font-size: 18px;
  font-weight: bold;
  color: #1e293b;
}

/* Main content */
.main-content.data-v-faae53d7 {
  height: calc(100vh - 60px);
  padding: 15px;
}

/* Search bar */
.search-section.data-v-faae53d7 {
  margin-bottom: 20px;
}
.search-input-wrapper.data-v-faae53d7 {
  position: relative;
  display: flex;
  align-items: center;
  background: white;
  border-radius: 24px;
  padding: 10px 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}
.search-icon.data-v-faae53d7 {
  font-size: 16px;
  margin-right: 8px;
}
.search-input.data-v-faae53d7 {
  flex: 1;
  font-size: 14px;
  border: none;
  outline: none;
  background: transparent;
}
.search-clear.data-v-faae53d7 {
  font-size: 14px;
  color: #94a3b8;
  padding: 4px 8px;
}

/* Exhibition list */
.exhibition-list.data-v-faae53d7 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15px;
}
.snake-card.data-v-faae53d7 {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}
.snake-card.data-v-faae53d7:active {
  transform: scale(0.95);
}
.snake-image.data-v-faae53d7 {
  width: 100%;
  height: 140px;
  background: #f1f5f9;
}
.snake-info.data-v-faae53d7 {
  padding: 12px;
}
.snake-header.data-v-faae53d7 {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 8px;
}
.snake-name.data-v-faae53d7 {
  font-size: 16px;
  font-weight: 600;
  color: #1e293b;
}
.snake-alias.data-v-faae53d7 {
  font-size: 12px;
  color: #64748b;
}
.snake-tags.data-v-faae53d7 {
  display: flex;
  gap: 6px;
  margin-bottom: 8px;
}
.tag.data-v-faae53d7 {
  font-size: 11px;
  padding: 3px 8px;
  border-radius: 12px;
  font-weight: 500;
}
.venom-tag.neurotoxic.data-v-faae53d7 {
  background: #dbeafe;
  color: #1d4ed8;
}
.venom-tag.hemotoxic.data-v-faae53d7 {
  background: #fee2e2;
  color: #dc2626;
}
.venom-tag.mixed.data-v-faae53d7 {
  background: #fef3c7;
  color: #d97706;
}
.region-tag.data-v-faae53d7 {
  background: #e0e7ff;
  color: #4338ca;
}
.snake-desc.data-v-faae53d7 {
  font-size: 12px;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Empty state */
.empty-state.data-v-faae53d7 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}
.empty-icon.data-v-faae53d7 {
  font-size: 64px;
  margin-bottom: 16px;
}
.empty-text.data-v-faae53d7 {
  font-size: 14px;
  color: #94a3b8;
}

/* Load more */
.load-more.data-v-faae53d7 {
  text-align: center;
  padding: 20px;
}
.load-text.data-v-faae53d7 {
  font-size: 13px;
  color: #64748b;
}

/* Pagination */
.pagination.data-v-faae53d7 {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  padding: 20px;
  background: white;
  border-radius: 12px;
  margin-top: 15px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}
.pagination-btn.data-v-faae53d7 {
  padding: 8px 16px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
}
.pagination-btn.disabled.data-v-faae53d7 {
  opacity: 0.4;
  cursor: not-allowed;
}
.page-numbers.data-v-faae53d7 {
  display: flex;
  gap: 6px;
}
.page-number.data-v-faae53d7 {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  color: #64748b;
}
.page-number.active.data-v-faae53d7 {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
}